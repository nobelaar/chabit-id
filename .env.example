PORT=3001

PG_HOST=localhost
PG_PORT=5432
PG_USER=chabit
PG_PASSWORD=chabit
PG_DATABASE=chabit_identity
PG_POOL_MAX=20
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECTION_TIMEOUT_MS=5000

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Generar con: openssl rand -hex 32
OTP_HMAC_SECRET=change-me-in-production

# Generar con: openssl rand -hex 32
JWT_SECRET=change-me-in-production
LOG_LEVEL=info

# SMTP — si no se configura, se usa StubEmailSender (loggea el OTP en consola)
# Para Postfix local sin auth:
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_SECURE=false
SMTP_FROM=noreply@chabit.com
# Credenciales opcionales (si el relay requiere auth):
SMTP_USER=
SMTP_PASS=

# Webhook — chabit-identity notifica a backend-chabit al completar el registro
WEBHOOK_BACKEND_URL=http://localhost:3000/internal/webhooks/identity
# Generar con: openssl rand -hex 32
WEBHOOK_SECRET=change-me-in-production
